[user]
  name = Oğulcan Girginç
  email = ogulcan@girginc.com

[init]
  defaultBranch = main

[core]
  editor = nvim
  commentChar = ";"
	pager = delta

[push]
  autoSetupRemote = true
	default = current

[alias]
  sb   = "!f() { git switch $(git branch | fzf --height 40% --reverse --border); }; f"
  srb  = "!f() { git switch -t $(git branch -r | fzf --height 40% --reverse --border); }; f"
  ssb  = "!f() { git add . && git stash && git switch $(git branch | fzf --height 40% --reverse --border) && git stash pop; }; f"
  sc    = switch -c

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[commit]
  verbose = true

[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictStyle = zdiff3

[rebase]
  updateRefs = true

[diff]
  colorMoved = default

[delta]
	navigate = true
  side-by-side = true
  dark = true
  true-color = always
